{
  "schema": "winmint.releaseManifest.v1",
  "include": [
    "WinMint-CLI.ps1",
    "WinMint-GUI.ps1",
    "LICENSE",
    "README.md",
    "THIRD_PARTY_NOTICES.md",
    "PSScriptAnalyzerSettings.psd1",
