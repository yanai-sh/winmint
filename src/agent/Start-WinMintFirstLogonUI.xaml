<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinMint Setup"
        Width="620" Height="560"
        MinWidth="560" MinHeight="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        Background="#101114">
  <Window.Resources>
    <Style TargetType="Button">
      <Setter Property="Padding" Value="16,8"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
  </Window.Resources>
  <Border Margin="14" CornerRadius="10" Background="#181A20" BorderBrush="#2B3240" BorderThickness="1">
  <Grid Margin="24,20,24,20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="14"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="18"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="12"/>
      <RowDefinition Height="4"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="12"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel>
        <TextBlock Text="WinMint FirstLogon" FontSize="22" FontWeight="SemiBold"
                   Foreground="#F4F7FB"/>
        <TextBlock x:Name="TxtHeader" Margin="0,5,0,0"
                   FontSize="13" Foreground="#AAB2C0" TextWrapping="Wrap"/>
      </StackPanel>
      <Border Grid.Column="1" Background="#123E68" CornerRadius="14"
              Padding="12,5" VerticalAlignment="Top">
        <TextBlock Text="Live setup" FontSize="12" Foreground="#D8EAFF"/>
      </Border>
    </Grid>

    <Border Grid.Row="2" CornerRadius="8" Background="#111820"
            BorderBrush="#27425E" BorderThickness="1" Padding="14,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="1.05*"/>
          <ColumnDefinition Width="1.45*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
          <TextBlock Text="Selected loadout" FontSize="12" Foreground="#7F8EA3"/>
          <TextBlock x:Name="TxtLoadoutProfile" Margin="0,5,0,0"
                     FontSize="16" FontWeight="SemiBold" Foreground="#EEF6FF"/>
        </StackPanel>
        <Grid Grid.Column="1" Margin="18,0,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="74"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Editors" Foreground="#7F8EA3" FontSize="12"/>
          <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtLoadoutEditors"
                     Foreground="#D8E3F1" FontSize="12" TextWrapping="Wrap"/>
          <TextBlock Grid.Row="1" Grid.Column="0" Text="WSL" Foreground="#7F8EA3" FontSize="12" Margin="0,5,0,0"/>
          <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtLoadoutWsl"
                     Foreground="#D8E3F1" FontSize="12" TextWrapping="Wrap" Margin="0,5,0,0"/>
          <TextBlock Grid.Row="2" Grid.Column="0" Text="Desktop" Foreground="#7F8EA3" FontSize="12" Margin="0,5,0,0"/>
          <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtLoadoutDesktop"
                     Foreground="#D8E3F1" FontSize="12" TextWrapping="Wrap" Margin="0,5,0,0"/>
        </Grid>
      </Grid>
    </Border>

    <Border Grid.Row="4" CornerRadius="8" Background="#14161B"
            BorderBrush="#2B3240" BorderThickness="1" Padding="14,10">
      <StackPanel x:Name="StepPanel"/>
    </Border>

    <ProgressBar Grid.Row="6" x:Name="FLProgressBar" Height="4"
                 IsIndeterminate="True" Foreground="#2F7DD1" Background="#252A33"/>

    <TextBlock Grid.Row="7" x:Name="TxtStatus"
               Text="Starting the hidden WinMint agent. You can leave this window open."
               Foreground="#8894A6" FontSize="12" TextWrapping="Wrap" Margin="0,6,0,0"/>

    <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button x:Name="BtnRestart" Content="Restart now"
              Visibility="Collapsed" Margin="0,0,8,0"
              Background="#1B5D8F"/>
      <Button x:Name="BtnRetry" Content="Retry failed"
              Visibility="Collapsed" Margin="0,0,8,0"
              Background="#26384D"/>
      <Button x:Name="BtnClose" Content="Close" IsEnabled="False"
              Background="#1F6F4A"/>
    </StackPanel>
  </Grid>
  </Border>
</Window>
