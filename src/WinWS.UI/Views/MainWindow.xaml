<ui:FluentWindow
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    x:Name="RootWindow"
    Title="WinMint"
    Width="1020"
    Height="680"
    MinWidth="980"
    MinHeight="640"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    Background="Transparent"
    Foreground="{DynamicResource WindowForegroundBrush}"
    FontFamily="Segoe UI Variable Text, Segoe UI"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True">

  <ui:FluentWindow.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ui:ThemesDictionary Theme="Dark" />
        <ui:ControlsDictionary />
      </ResourceDictionary.MergedDictionaries>


      <LinearGradientBrush x:Key="SlimWordmarkBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F7F2E7" Offset="0"/>
        <GradientStop Color="#62C7FF" Offset="0.42"/>
        <GradientStop Color="#8FD2FF" Offset="0.72"/>
        <GradientStop Color="#F8F3EA" Offset="1"/>
      </LinearGradientBrush>

      <Style x:Key="OptionIconImage" TargetType="Image">
        <Setter Property="Width" Value="20"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Stretch" Value="Uniform"/>
        <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality"/>
      </Style>

      <Style x:Key="OptionIconPath" TargetType="Path">
        <Setter Property="Width" Value="20"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Stretch" Value="Uniform"/>
      </Style>

      <Style x:Key="PremiumPrimaryButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource ButtonFgBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="18,10"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border x:Name="ButtonBorder"
                      Background="{DynamicResource AccentBrush}"
                      BorderThickness="0"
                      CornerRadius="8"
                      Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                  <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AccentPressBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource TextDisabled}"/>
                  <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <Style x:Key="PremiumSecondaryButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="18,10"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border x:Name="ButtonBorder"
                      Background="Transparent"
                      BorderBrush="{DynamicResource FieldBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="8"
                      Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource PickerHover}"/>
                  <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource TextSecondary}"/>
                  <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AccentDimBrush}"/>
                  <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter Property="Foreground" Value="{DynamicResource TextDisabled}"/>
                  <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource TextDisabled}"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <Style x:Key="PremiumSuccessButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource ButtonFgBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="18,10"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border x:Name="ButtonBorder"
                      Background="{DynamicResource SuccessBrush}"
                      BorderThickness="0"
                      CornerRadius="8"
                      Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource SuccessHoverBrush}"/>
                  <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource SuccessPressBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource TextDisabled}"/>
                  <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>


      <!-- Implicit CheckBox - modern rounded square checkmark globally applied -->
      <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Margin" Value="0,6"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="CheckBox">
              <Grid x:Name="RootGrid" Background="Transparent">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="22"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="CheckBorder" Width="18" Height="18"
                        BorderBrush="{DynamicResource FieldBorderBrush}"
                        BorderThickness="1.5"
                        CornerRadius="4"
                        Background="Transparent"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                  <Path x:Name="CheckMark"
                        Data="M3,8 L7,12 L14,4"
                        Stroke="{DynamicResource ButtonFgBrush}"
                        StrokeThickness="2"
                        StrokeStartLineCap="Round"
                        StrokeEndLineCap="Round"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>
                <ContentPresenter Grid.Column="1"
                                  Margin="8,0,0,0"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Left"/>
              </Grid>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource TextSecondary}"/>
                  <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                  <Setter TargetName="CheckBorder" Property="Background" Value="{DynamicResource AccentBrush}"/>
                  <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                  <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter TargetName="RootGrid" Property="Opacity" Value="0.5"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Implicit RadioButton - sleek Fluent dot globally applied -->
      <Style TargetType="RadioButton">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Margin" Value="0,6"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="RadioButton">
              <Grid x:Name="RootGrid" Background="Transparent">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="22"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Ellipse x:Name="OuterRing" Width="18" Height="18"
                         Stroke="{DynamicResource FieldBorderBrush}"
                         StrokeThickness="1.5"
                         Fill="Transparent"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"/>
                <Ellipse x:Name="InnerDot" Width="10" Height="10"
                         Fill="{DynamicResource AccentBrush}"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         Margin="4,0,0,0"
                         Visibility="Collapsed"/>
                <ContentPresenter Grid.Column="1"
                                  Margin="8,0,0,0"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Left"/>
              </Grid>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="OuterRing" Property="Stroke" Value="{DynamicResource TextSecondary}"/>
                  <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                  <Setter TargetName="OuterRing" Property="Stroke" Value="{DynamicResource AccentBrush}"/>
                  <Setter TargetName="OuterRing" Property="StrokeThickness" Value="2"/>
                  <Setter TargetName="InnerDot" Property="Visibility" Value="Visible"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter TargetName="RootGrid" Property="Opacity" Value="0.5"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- PremiumCardRadioButton - side-by-side selection tiles for dashboard-style options -->
      <Style x:Key="PremiumCardRadioButton" TargetType="RadioButton">
        <Setter Property="MinHeight" Value="96"/>
        <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FieldBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="18,16"/>
        <Setter Property="Margin" Value="0,0,0,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="RadioButton">
              <Border x:Name="CardBorder"
                      Background="{DynamicResource CardBrush}"
                      BorderBrush="{DynamicResource FieldBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="8"
                      Padding="{TemplateBinding Padding}">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>

                  <ContentPresenter VerticalAlignment="Center"/>

                  <!-- Stylish dot indicator on the right side -->
                  <Grid Grid.Column="1" VerticalAlignment="Top" Margin="12,2,0,0" HorizontalAlignment="Right">
                    <Ellipse x:Name="OuterRing" Width="18" Height="18" Stroke="{DynamicResource FieldBorderBrush}" StrokeThickness="1.5" Fill="Transparent"/>
                    <Ellipse x:Name="InnerDot" Width="10" Height="10" Fill="{DynamicResource AccentBrush}" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Grid>
                </Grid>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource PickerHover}"/>
                  <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource TextSecondary}"/>
                  <Setter TargetName="OuterRing" Property="Stroke" Value="{DynamicResource TextSecondary}"/>
                  <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                  <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource AccentDimBrush}"/>
                  <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                  <Setter TargetName="OuterRing" Property="Stroke" Value="{DynamicResource AccentBrush}"/>
                  <Setter TargetName="OuterRing" Property="StrokeThickness" Value="2"/>
                  <Setter TargetName="InnerDot" Property="Visibility" Value="Visible"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter TargetName="CardBorder" Property="Opacity" Value="0.4"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

    </ResourceDictionary>
  </ui:FluentWindow.Resources>

  <ui:FluentWindow.Triggers>
    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
      <BeginStoryboard>
        <Storyboard>
          <DoubleAnimation Storyboard.TargetName="StageHost" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6">
            <DoubleAnimation.EasingFunction>
              <CubicEase EasingMode="EaseOut"/>
            </DoubleAnimation.EasingFunction>
          </DoubleAnimation>
          <ThicknessAnimation Storyboard.TargetName="StageHost" Storyboard.TargetProperty="Margin" From="42,50,42,4" To="42,30,42,24" Duration="0:0:0.6">
            <ThicknessAnimation.EasingFunction>
              <CubicEase EasingMode="EaseOut"/>
            </ThicknessAnimation.EasingFunction>
          </ThicknessAnimation>
        </Storyboard>
      </BeginStoryboard>
    </EventTrigger>
  </ui:FluentWindow.Triggers>

  <Border Background="{ui:ThemeResource ApplicationBackgroundBrush}"
          BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="1"
          CornerRadius="8"
          ClipToBounds="True">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="56"/>
        <RowDefinition Height="*"/>
        <RowDefinition x:Name="FooterRowDef" Height="72"/>
      </Grid.RowDefinitions>

      <ui:TitleBar Grid.Row="0"
                   Background="{ui:ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                   Padding="28,0,16,0">
        <ui:TitleBar.Header>
          <Grid VerticalAlignment="Center" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Viewbox x:Name="TopWordmark"
                     Tag="assets\brand\WinMint.svg"
                     Width="128"
                     Height="28"
                     Stretch="Uniform"
                     VerticalAlignment="Center"
                     Visibility="Collapsed">
              <StackPanel Orientation="Horizontal">
                <ui:TextBlock Text="WinMint" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="34" FontWeight="Black" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
              </StackPanel>
            </Viewbox>

            <StackPanel x:Name="TitleBarBreadcrumb" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,18,0" Visibility="Collapsed">
              <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                <Ellipse x:Name="StepDotStart" Width="7" Height="7" Fill="{ui:ThemeResource SystemAccentColorPrimaryBrush}" Margin="0,0,6,0"/>
                <ui:TextBlock x:Name="StepLabelStart" Text="Source" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" FontSize="12"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                <Ellipse x:Name="StepDotMachine" Width="7" Height="7" Fill="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Margin="0,0,6,0"/>
                <ui:TextBlock x:Name="StepLabelMachine" Text="Machine" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" FontSize="12"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                <Ellipse x:Name="StepDotDisk" Width="7" Height="7" Fill="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Margin="0,0,6,0"/>
                <ui:TextBlock x:Name="StepLabelDisk" Text="Disk" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" FontSize="12"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                <Ellipse x:Name="StepDotProfile" Width="7" Height="7" Fill="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Margin="0,0,6,0"/>
                <ui:TextBlock x:Name="StepLabelProfile" Text="Identity" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" FontSize="12"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                <Ellipse x:Name="StepDotWorkstation" Width="7" Height="7" Fill="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Margin="0,0,6,0"/>
                <ui:TextBlock x:Name="StepLabelWorkstation" Text="Workstation" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" FontSize="12"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StepDotLaunch" Width="7" Height="7" Fill="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Margin="0,0,6,0"/>
                <ui:TextBlock x:Name="StepLabelLaunch" Text="Launch" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" FontSize="12"/>
              </StackPanel>
            </StackPanel>
          </Grid>
        </ui:TitleBar.Header>
      </ui:TitleBar>

      <Grid Grid.Row="1" x:Name="StageHost" Margin="42,30,42,24">
        <Grid x:Name="StageStart" Visibility="Visible">
          <!-- Cinematic full-bleed splash: wordmark + single action -->
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="520">
            <!-- Hero wordmark — centered, cinematic -->
            <Viewbox x:Name="HeroWordmark"
                     Tag="assets\brand\WinMint.svg"
                     Width="420"
                     Height="110"
                     Stretch="Uniform"
                     HorizontalAlignment="Center">
              <StackPanel Orientation="Horizontal">
                <ui:TextBlock Text="WinMint" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="72" FontWeight="Black" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
              </StackPanel>
            </Viewbox>

            <ui:TextBlock Text="Build a clean Windows workstation ISO."
                       FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"
                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       Margin="0,18,0,0"/>

            <!-- ISO metadata pills — hidden until verified -->
            <StackPanel x:Name="SourceMetaPills" Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,32,0,0" Visibility="Collapsed">
              <Border Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1" CornerRadius="14" Padding="14,6">
                <StackPanel Orientation="Horizontal">
                  <ui:TextBlock x:Name="TxtIsoArchitecture" Text="x64"
                             FontSize="13" FontWeight="SemiBold"
                             Foreground="{ui:ThemeResource SystemAccentColorPrimaryBrush}"
                             VerticalAlignment="Center"/>
                  <Rectangle Width="1" Height="14" Fill="{ui:ThemeResource CardStrokeColorDefaultBrush}" Margin="12,0"/>
                  <ui:TextBlock x:Name="TxtIsoEditions" Text="Home, Pro"
                             FontSize="13"
                             Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                             VerticalAlignment="Center"/>
                </StackPanel>
              </Border>
            </StackPanel>

            <!-- Status text (shown during verification) -->
            <ui:TextBlock x:Name="TxtIsoStatus" Text="" FontTypography="Body"
                       TextWrapping="Wrap" TextAlignment="Center"
                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                       HorizontalAlignment="Center" Margin="0,16,0,0"/>

            <!-- Verification spinner — hidden until verifying -->
            <ProgressBar x:Name="SourceVerifySpinner" IsIndeterminate="True"
                         Visibility="Collapsed" Margin="40,8,40,0"/>

            <!-- The single action button: Browse ISO → verifying... → Next -->
            <Button x:Name="BtnBrowseIso"
                    Content="Browse ISO"
                    AutomationProperties.Name="Choose ISO"
                    Style="{StaticResource PremiumPrimaryButton}"
                    HorizontalAlignment="Center"
                    MinWidth="220" MinHeight="40"
                    Margin="0,28,0,0"/>

            <!-- Hidden path holder for automation / state sync -->
            <ui:TextBox x:Name="TxtIsoPath" IsReadOnly="True" Visibility="Collapsed"/>
          </StackPanel>

          <!-- Hidden elements that code-behind references but are not displayed on splash -->
          <ui:TextBlock x:Name="TxtIsoArchitectureCaption" Text="" Visibility="Collapsed"/>
        </Grid>

        <Grid x:Name="StageMachine" Visibility="Collapsed">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="390"/>
            <ColumnDefinition Width="34"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <Border Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="26">
            <StackPanel VerticalAlignment="Center">
              <ui:TextBlock Text="TARGET" FontTypography="BodyStrong" FontSize="12" Foreground="{ui:ThemeResource SystemAccentColorPrimaryBrush}"/>
              <ui:TextBlock x:Name="TxtMachineTargetSummary" Text="Another PC" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" FontSize="34" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,20,0,10"/>
              <ui:TextBlock x:Name="TxtMachineDetailSummary" Text="ISO default edition; Windows inbox drivers" FontTypography="Body" TextWrapping="Wrap" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
              <Border Background="{ui:ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="7" Margin="0,34,0,0">
                <StackPanel>
                  <ui:TextBlock Text="Driver policy" FontTypography="Caption" Margin="0,0,0,6" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                  <ui:TextBlock x:Name="TxtDriverPackName" Text="No driver pack selected" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" FontSize="15" FontWeight="SemiBold"/>
                  <ui:TextBlock x:Name="TxtDriverPackPath" Text="" FontTypography="Caption" TextWrapping="Wrap" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Margin="0,6,0,0"/>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <Grid Grid.Column="2">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel>
              <ui:TextBlock Text="Machine Type" FontTypography="Subtitle" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="12"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <RadioButton x:Name="RbTargetThisPc" GroupName="TargetMachine" Style="{StaticResource PremiumCardRadioButton}" IsChecked="True">
                  <StackPanel Margin="0,2,0,2">
                    <ui:TextBlock Text="This PC" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                    <ui:TextBlock Text="Optimize specifically for this local machine's hardware, drivers, and license." TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
                  </StackPanel>
                </RadioButton>
                <RadioButton x:Name="RbTargetDifferentPc" Grid.Column="2" GroupName="TargetMachine" Style="{StaticResource PremiumCardRadioButton}">
                  <StackPanel Margin="0,2,0,2">
                    <ui:TextBlock Text="Another PC" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                    <ui:TextBlock Text="Create a portable, generic ISO compatible with any standard modern hardware." TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
                  </StackPanel>
                </RadioButton>
              </Grid>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,24,0,0">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <ui:TextBlock Text="Driver Integration" FontTypography="Subtitle" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
              <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="10"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="10"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <RadioButton x:Name="RbDriverDefault" GroupName="Drivers" Style="{StaticResource PremiumCardRadioButton}" IsChecked="True">
                  <StackPanel Margin="0,2,0,2">
                    <ui:TextBlock Text="Windows Standard" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                    <ui:TextBlock Text="Standard inbox Microsoft drivers" TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
                  </StackPanel>
                </RadioButton>
                <RadioButton x:Name="RbDriverThisPc" Grid.Column="2" GroupName="Drivers" Style="{StaticResource PremiumCardRadioButton}">
                  <StackPanel Margin="0,2,0,2">
                    <ui:TextBlock Text="Host Drivers" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                    <ui:TextBlock Text="Clone and inject this PC's exact drivers" TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
                  </StackPanel>
                </RadioButton>
                <RadioButton x:Name="RbDriverCustom" Grid.Column="4" GroupName="Drivers" Style="{StaticResource PremiumCardRadioButton}">
                  <StackPanel Margin="0,2,0,2">
                    <ui:TextBlock Text="Custom drivers" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                    <ui:TextBlock Text="Folder of .inf/.msi, or one driver .inf or vendor .msi" TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
                  </StackPanel>
                </RadioButton>
              </Grid>
              <Grid Grid.Row="2" Margin="0,18,0,0">
