              </StackPanel>
            </Border>

            <Border x:Name="ContractWorkstationPanel" Grid.Row="2" Grid.Column="2" Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="18">
              <StackPanel>
                <ui:TextBlock Text="Workstation" FontTypography="Caption" Margin="0,0,0,6" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                <ui:TextBlock x:Name="ContractWorkstationPrimary" Text="Standard Windows" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap"/>
                <ui:TextBlock x:Name="ContractWorkstationSecondary" Text="No editors + No WSL" FontTypography="Body" TextWrapping="Wrap" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Margin="0,8,0,0"/>
                <ui:TextBlock x:Name="ContractWorkstationMeta" Text="Installed at first logon using winget." FontTypography="Caption" TextWrapping="Wrap" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Margin="0,12,0,0"/>
              </StackPanel>
            </Border>

            <Border x:Name="ContractOutputPanel" Grid.Row="2" Grid.Column="4" Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="18">
              <StackPanel>
                <ui:TextBlock Text="Output" FontTypography="Caption" Margin="0,0,0,6" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                <ui:TextBlock x:Name="ContractOutputPrimary" Text="WinMint.iso" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap"/>
                <ui:TextBlock x:Name="ContractOutputSecondary" Text="output" FontTypography="Body"  Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                <ui:TextBlock x:Name="ContractOutputMeta" Text="" FontTypography="Caption" TextWrapping="Wrap" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Margin="0,12,0,0"/>
              </StackPanel>
            </Border>
          </Grid>

          <Border x:Name="LaunchProgressPanel" Grid.Row="1" Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Visibility="Collapsed" Margin="0,24,0,0" Padding="22">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <ui:TextBlock Text="Build progress" FontTypography="Subtitle" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
              <ProgressBar x:Name="BuildProgress" Grid.Row="1" Minimum="0" Maximum="100" Value="0" Margin="0,8,0,18"/>
              <ScrollViewer x:Name="LogScrollViewer" Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="LogPanel"/>
              </ScrollViewer>
            </Grid>
          </Border>
        </Grid>
      </Grid>

      <Border x:Name="FooterBar" Grid.Row="2" Background="{ui:ThemeResource LayerOnAcrylicFillColorDefaultBrush}" BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
        <Grid Margin="34,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <ui:TextBlock x:Name="FooterStageNumber" Text="1" Foreground="{ui:ThemeResource SystemAccentColorPrimaryBrush}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Rectangle Width="58" Height="1" Fill="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Margin="16,0"/>
            <ui:TextBlock x:Name="FooterStageName" Text="Source" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
            <Button x:Name="BtnBack" Content="Back" Style="{StaticResource PremiumSecondaryButton}" MinWidth="124" Margin="0,0,12,0"/>
            <Button x:Name="BtnNext" Content="Next" Style="{StaticResource PremiumPrimaryButton}" MinWidth="136"/>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </Border>
</ui:FluentWindow>
