{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://winmint.yanai.sh/schemas/winmint.setupshellstatus.schema.json",
  "title": "WinMint Setup Shell Status",
  "description": "Display state written by WinMintSetupShell.Status.ps1 to %LOCALAPPDATA%\\WinMint\\setup-shell-status.json. Consumed by WinMintSetupShell.exe only. taskLabel is the stage title; detailLabel is the current item/sub-phase.",
  "type": "object",
  "required": [
    "phase",
    "stageId",
    "taskLabel",
    "detailLabel",
    "itemIndex",
    "itemTotal",
    "progressPct",
    "progressMode",
    "profileName",
    "elapsedMs",
    "banner",
    "bannerKind",
    "logDir",
    "updatedAt"
  ],
  "properties": {
    "phase": {
      "type": "string",
      "enum": ["running", "finishing", "complete", "failed", "reboot"]
    },
    "stageId": {
      "type": "string",
      "enum": ["ready", "apps", "wsl", "finish"]
    },
    "taskLabel": { "type": "string" },
    "detailLabel": { "type": "string" },
    "itemIndex": { "type": "integer", "minimum": 0 },
    "itemTotal": { "type": "integer", "minimum": 0 },
    "progressPct": { "type": "number", "minimum": 0, "maximum": 100 },
    "progressMode": { "type": "string", "enum": ["determinate", "indeterminate"] },
    "profileName": { "type": "string" },
    "elapsedMs": { "type": "integer", "minimum": 0 },
    "groupLabel": {
      "type": "string",
      "description": "Deprecated; unused by the presenter. Emitted as empty string for transitional readers."
    },
    "banner": { "type": "string" },
    "bannerKind": { "type": "string", "enum": ["", "warn", "fail"] },
    "logDir": { "type": "string" },
    "updatedAt": { "type": "string" }
  },
  "additionalProperties": false
}
