{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://winmint.local/schemas/winmint.uiintent.schema.json",
  "title": "WinMint UI intent",
  "type": "object",
  "required": [
    "Profile",
    "KeepEdge",
    "KeepGaming",
    "KeepCopilot",
    "ISOPath",
    "Architecture",
    "ComputerName",
    "AccountName",
    "AccountMode",
    "TargetDevice",
    "Edition",
    "DriverSource",
    "InstallWindhawk",
    "InstallYasb",
    "InstallKomorebi",
    "InstallNilesoft",
    "Editors",
    "Browsers",
    "Wsl2Distros"
  ],
  "properties": {
    "Profile": { "type": "string" },
    "KeepEdge": { "type": "boolean" },
    "KeepGaming": { "type": "boolean" },
    "KeepCopilot": { "type": "boolean" },
    "ISOPath": { "type": "string" },
    "Architecture": { "type": "string" },
    "ComputerName": { "type": "string" },
    "AccountName": { "type": "string" },
    "AccountMode": { "type": "string" },
    "TargetDevice": { "type": "string" },
    "FormFactor": { "type": "string" },
    "Edition": { "type": "string" },
    "DriverSource": { "type": "string" },
    "DriverPath": { "type": "string" },
    "InstallWindhawk": { "type": "boolean" },
    "InstallYasb": { "type": "boolean" },
    "InstallKomorebi": { "type": "boolean" },
    "InstallNilesoft": { "type": "boolean" },
    "Editors": { "type": "array", "items": { "type": "string" } },
    "Browsers": { "type": "array", "items": { "type": "string" } },
    "Wsl2Distros": { "type": "array", "items": { "type": "string" } },
    "PrivLocation": { "type": "boolean" },
    "TweakHardwareBypass": { "type": "boolean" },
    "TweakDmaInterop": { "type": "boolean" }
  },
  "additionalProperties": true
}
