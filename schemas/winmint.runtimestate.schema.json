{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://winmint.yanai.sh/schemas/winmint.runtimestate.schema.json",
  "title": "WinMint Runtime State",
  "description": "Unified live runtime state at %LOCALAPPDATA%\\WinMint\\runtime-state.json. Dual-written during Track 3 strangler migration; replaces setup-shell-control.json + setup-shell-status.json for readers. Agent resume remains in state.json.",
  "type": "object",
  "required": ["schemaVersion", "updatedAt", "control", "display", "agent"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "updatedAt": { "type": "string" },
    "control": {
      "type": "object",
      "required": ["phase", "startedAt", "updatedAt", "profileName", "message", "preAgentStage"],
      "properties": {
        "phase": {
          "type": "string",
          "enum": ["running", "finishing", "complete", "failed", "reboot"]
        },
        "startedAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "profileName": { "type": "string" },
        "message": { "type": "string" },
        "preAgentStage": {
          "type": "string",
          "enum": ["", "locked", "region", "defaults", "agent"]
        }
      },
      "additionalProperties": false
    },
    "display": {
      "type": "object",
      "required": [
        "phase",
        "stageId",
        "taskLabel",
        "detailLabel",
        "itemIndex",
        "itemTotal",
        "progressPct",
        "progressMode",
        "profileName",
        "elapsedMs",
        "banner",
        "bannerKind",
        "logDir",
        "updatedAt"
      ],
      "properties": {
        "phase": {
          "type": "string",
          "enum": ["running", "finishing", "complete", "failed", "reboot"]
        },
        "stageId": {
          "type": "string",
          "enum": ["ready", "apps", "wsl", "finish"]
        },
        "taskLabel": { "type": "string" },
        "detailLabel": { "type": "string" },
        "itemIndex": { "type": "integer", "minimum": 0 },
        "itemTotal": { "type": "integer", "minimum": 0 },
        "progressPct": { "type": "number", "minimum": 0, "maximum": 100 },
        "progressMode": { "type": "string", "enum": ["determinate", "indeterminate"] },
        "profileName": { "type": "string" },
        "elapsedMs": { "type": "integer", "minimum": 0 },
        "groupLabel": {
          "type": "string",
          "description": "Deprecated; unused by the presenter."
        },
        "banner": { "type": "string" },
        "bannerKind": { "type": "string", "enum": ["", "warn", "fail"] },
        "logDir": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "additionalProperties": false
    },
    "agent": {
      "type": "object",
      "required": ["runStatus", "currentStep", "runningSteps", "completedSteps", "totalSteps", "updatedAt"],
      "properties": {
        "runStatus": { "type": "string" },
        "currentStep": { "type": "string" },
        "runningSteps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "completedSteps": { "type": "integer", "minimum": 0 },
        "totalSteps": { "type": "integer", "minimum": 0 },
        "updatedAt": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
