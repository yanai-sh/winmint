{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://winmint.yanai.sh/schemas/winmint.buildmanifest.schema.json",
  "title": "WinMint Build Manifest",
  "type": "object",
  "allOf": [
    {
      "if": {
        "properties": {
          "target": {
            "properties": {
              "diskMode": { "const": "DualBootReserved" }
            }
          }
        }
      },
      "then": {
        "properties": {
          "target": {
            "properties": {
              "diskLayout": {
                "properties": {
                  "mode": { "const": "DualBootReserved" },
                  "preset": { "enum": ["WindowsHeavy", "Balanced", "EvenSplit", "LinuxHeavy"] }
                }
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "target": {
            "properties": {
              "diskLayout": {
                "properties": {
                  "preset": { "const": "" }
                }
              }
            }
          }
        }
      }
    }
  ],
  "required": [
    "schemaVersion",
    "builtAt",
    "buildResult",
    "source",
    "target",
    "regional",
    "removals",
    "sizeDelta",
    "servicing",
    "tweaks",
    "policies",
    "drivers",
    "payloads",
    "firstLogon",
    "audit",
    "riskFlags"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 2
    },
    "builtAt": {
      "type": "string",
      "description": "ISO 8601 timestamp when the build started"
    },
    "buildDurationSeconds": {
      "type": "number"
    },
    "buildResult": {
      "type": "string",
      "enum": ["success", "failed", "dry-run"]
    },
    "source": {
      "type": "object",
      "required": ["isoPath", "architecture", "editions"],
      "additionalProperties": false,
      "properties": {
        "isoPath": { "type": "string" },
        "architecture": { "type": "string" },
        "editions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "output": {
      "type": "object",
      "required": ["isoPath", "sha256", "sizeBytes"],
      "additionalProperties": false,
      "properties": {
        "isoPath": { "type": "string" },
        "sha256": { "type": "string" },
        "sizeBytes": { "type": "integer" }
      }
    },
    "usbMedia": {
      "type": "object",
      "required": ["enabled", "status", "diskNumber"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "status": { "type": "string", "enum": ["ok", "failed"] },
        "writtenAt": { "type": "string" },
        "diskNumber": { "type": "integer" },
        "diskModel": { "type": "string" },
        "diskSizeBytes": { "type": "integer" },
        "partitionScheme": { "type": "string", "const": "GPT" },
        "bootMode": { "type": "string", "const": "UEFI" },
        "installFilesystem": { "type": "string", "const": "NTFS" },
        "installDrive": { "type": "string" },
        "helper": { "type": "string", "const": "UEFI:NTFS" },
        "helperVersion": { "type": "string" },
        "helperSourceUrl": { "type": "string" },
        "helperSha256": { "type": "string" },
        "architecture": { "type": "string" },
        "error": { "type": "string" }
      }
    },
    "target": {
      "type": "object",
      "required": ["diskMode", "diskLayout", "primaryAssumption"],
      "additionalProperties": false,
      "properties": {
        "diskMode": { "type": "string", "enum": ["Manual", "AutoWipeDisk0", "DualBootReserved"] },
        "diskLayout": {
          "type": "object",
          "required": ["mode", "preset", "roundingGb", "windowsMinimumGb", "windowsRecommendedGb", "linuxMinimumGb", "linuxRecommendedGb", "efiMb", "msrMb", "recoveryMb"],
          "additionalProperties": false,
          "properties": {
            "mode": { "type": "string", "enum": ["Manual", "AutoWipeDisk0", "DualBootReserved"] },
            "preset": { "type": "string", "enum": ["", "WindowsHeavy", "Balanced", "EvenSplit", "LinuxHeavy"] },
            "roundingGb": { "type": "integer" },
            "windowsMinimumGb": { "type": "integer" },
            "windowsRecommendedGb": { "type": "integer" },
            "linuxMinimumGb": { "type": "integer" },
            "linuxRecommendedGb": { "type": "integer" },
            "efiMb": { "type": "integer" },
            "msrMb": { "type": "integer" },
            "recoveryMb": { "type": "integer" }
          }
        },
        "primaryAssumption": { "type": "string", "const": "Windows11HomeSingleLanguageEnUS" }
      }
    },
    "regional": {
      "type": "object",
      "required": ["timeZoneId", "uiLanguage", "systemLocale", "userLocale", "inputLocale", "homeLocationGeoId", "dmaInterop"],
      "additionalProperties": false,
      "properties": {
        "timeZoneId": { "type": "string" },
        "uiLanguage": { "type": "string" },
        "systemLocale": { "type": "string" },
        "userLocale": { "type": "string" },
        "inputLocale": { "type": "string" },
        "homeLocationGeoId": { "type": "integer" },
        "dmaInterop": {
          "type": "object",
          "required": ["enabled", "defaultEnabled", "setupCountry", "setupUserLocale", "setupHomeLocationGeoId", "restoreUserLocale", "restoreHomeLocationGeoId"],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "defaultEnabled": { "type": "boolean" },
            "setupCountry": { "type": "string" },
            "setupUserLocale": { "type": "string" },
            "setupHomeLocationGeoId": { "type": "integer" },
            "setupLatchedCountry": { "type": "string" },
            "setupLatchedGeoId": { "type": "integer" },
            "restoreUserLocale": { "type": "string" },
            "restoreHomeLocationGeoId": { "type": "integer" },
            "restoredUserLocale": { "type": "string" },
            "restoredHomeLocationGeoId": { "type": "integer" },
            "restoredTimeZoneId": { "type": "string" },
            "locationServicesPolicy": { "type": "string", "enum": ["enabled", "disabled", "unchanged"] }
          }
        }
      }
    },
    "removals": {
      "type": "object",
      "required": ["appxPrefixes", "appxCatalogVersion", "appxRemoved", "appxRemovedCount", "capabilitiesRemoved", "windowsPackagesRemoved", "languagePackagesRemoved", "languagePackagesRemovedCount", "oobeRehydration", "featuresEnabled", "ai"],
      "additionalProperties": false,
      "properties": {
        "appxPrefixes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "appxCatalogVersion": { "type": "integer", "minimum": 1 },
        "appxRemoved": {
          "type": "array",
          "items": { "type": "string" }
        },
        "appxRemovedCount": {
          "type": "integer",
          "minimum": 0
        },
        "capabilitiesRemoved": {
          "type": "array",
          "items": { "type": "string" }
        },
        "windowsPackagesRemoved": {
          "type": "array",
          "items": { "type": "string" }
        },
        "languagePackagesRemoved": {
          "type": "array",
          "items": { "type": "string" }
        },
        "languagePackagesRemovedCount": {
          "type": "integer",
          "minimum": 0
        },
        "oobeRehydration": {
          "type": "object",
          "required": ["blocked", "workCompleted", "failed"],
          "additionalProperties": false,
          "properties": {
            "blocked": {
              "type": "array",
              "items": { "type": "string" }
            },
            "workCompleted": {
              "type": "array",
              "items": { "type": "string" }
            },
            "failed": {
              "type": "array",
              "items": { "type": "object" }
            }
          }
        },
        "featuresEnabled": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ai": {
          "type": "object",
          "required": ["policy", "catalogVersion", "appxPrefixes", "appxRemoved", "optionalFeaturesRemoved", "registryPoliciesApplied", "servicesDisabled", "scheduledTasksDisabled", "aggressiveActions", "failed", "recoveryBundlePath"],
          "additionalProperties": false,
          "properties": {
            "policy": { "type": "string", "enum": ["Core", "ServiceableFull", "AggressiveExperimental"] },
            "catalogVersion": { "type": "integer", "minimum": 1 },
            "appxPrefixes": {
              "type": "array",
              "items": { "type": "string" }
            },
            "appxRemoved": {
              "type": "array",
              "items": { "type": "string" }
            },
            "optionalFeaturesRemoved": {
              "type": "array",
              "items": { "type": "string" }
            },
            "registryPoliciesApplied": {
              "type": "array",
              "items": { "type": "string" }
            },
            "servicesDisabled": {
              "type": "array",
              "items": { "type": "string" }
            },
            "scheduledTasksDisabled": {
              "type": "array",
              "items": { "type": "string" }
            },
            "aggressiveActions": {
              "type": "array",
              "items": { "type": "string" }
            },
            "failed": {
              "type": "array",
              "items": { "type": "object" }
            },
            "recoveryBundlePath": { "type": "string" }
          }
        },
        "oneDriveSetupStubs": {
          "type": "object",
          "required": ["intent", "removed", "notFound", "failed"],
          "additionalProperties": false,
          "properties": {
            "intent": { "type": "string" },
            "removed": {
              "type": "array",
              "items": { "type": "string" }
            },
            "notFound": {
              "type": "array",
              "items": { "type": "string" }
            },
            "failed": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["path", "error"],
                "additionalProperties": false,
                "properties": {
                  "path": { "type": "string" },
                  "error": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "sizeDelta": {
      "type": "object",
      "required": [
        "sourceIsoBytes",
        "installWimBeforeServicingBytes",
        "installWimAfterServicingBytes",
        "installWimAfterExportBytes",
        "outputIsoBytes",
        "outputMinusSourceBytes",
        "outputToSourceRatio"
      ],
      "additionalProperties": false,
      "properties": {
        "sourceIsoBytes": { "type": "integer", "minimum": 0 },
        "installWimBeforeServicingBytes": { "type": "integer", "minimum": 0 },
        "installWimAfterServicingBytes": { "type": "integer", "minimum": 0 },
        "installWimAfterExportBytes": { "type": "integer", "minimum": 0 },
        "outputIsoBytes": { "type": "integer", "minimum": 0 },
        "outputMinusSourceBytes": { "type": "integer" },
        "outputToSourceRatio": { "type": "number", "minimum": 0 }
      }
    },
    "servicing": {
      "type": "object",
      "required": ["componentCleanup", "exportCompression", "resetBase", "serviceabilityPolicy", "updates"],
      "additionalProperties": false,
      "properties": {
        "componentCleanup": { "type": "string" },
        "exportCompression": { "type": "string", "enum": ["Max", "Fast", "None"] },
        "resetBase": { "type": "boolean" },
        "serviceabilityPolicy": { "type": "string" },
        "updates": {
          "type": "object",
          "required": [
            "mode",
            "targetFeatureVersion",
            "releaseCadence",
            "includeOptionalPreviews",
            "payloadRoot",
            "qualitySecurity",
            "dynamicUpdate",
            "defender",
            "dotnet",
            "provisionedApps",
            "appliedPackages",
            "provisionedAppx",
            "skipped",
            "failed"
          ],
          "additionalProperties": false,
          "properties": {
            "mode": { "type": "string", "enum": ["None", "Stable25H2"] },
            "targetFeatureVersion": { "type": "string" },
            "releaseCadence": { "type": "string" },
            "includeOptionalPreviews": { "type": "boolean" },
            "payloadRoot": { "type": "string" },
            "qualitySecurity": { "type": "boolean" },
            "dynamicUpdate": { "type": "boolean" },
            "defender": { "type": "boolean" },
            "dotnet": { "type": "boolean" },
            "provisionedApps": { "type": "boolean" },
            "appliedPackages": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["category", "path", "sha256", "sizeBytes"],
                "additionalProperties": false,
                "properties": {
                  "category": { "type": "string" },
                  "path": { "type": "string" },
                  "sha256": { "type": "string" },
                  "sizeBytes": { "type": "integer" }
                }
              }
            },
            "provisionedAppx": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["path", "sha256", "sizeBytes", "dependencyCount"],
                "additionalProperties": false,
                "properties": {
                  "path": { "type": "string" },
                  "sha256": { "type": "string" },
                  "sizeBytes": { "type": "integer" },
                  "dependencyCount": { "type": "integer" }
                }
              }
            },
            "skipped": { "type": "array", "items": { "type": "string" } },
            "failed": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["category", "path", "error"],
                "additionalProperties": false,
                "properties": {
                  "category": { "type": "string" },
                  "path": { "type": "string" },
                  "error": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "setupPlan": {
      "type": "object",
      "required": ["schemaVersion", "accountMode", "editionMode", "diskMode", "phases", "stagedArtifacts", "firstLogonModules", "notes"],
      "additionalProperties": false,
      "properties": {
        "schemaVersion": { "type": "integer", "minimum": 1 },
        "accountMode": { "type": "string" },
        "editionMode": { "type": "string" },
        "diskMode": { "type": "string" },
        "phases": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "context", "entrypoint", "responsibilities"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "context": { "type": "string" },
              "entrypoint": { "type": "string" },
              "responsibilities": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "stagedArtifacts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "firstLogonModules": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "tweaks": {
      "type": "object",
      "required": ["registryGroupsApplied"],
      "additionalProperties": false,
      "properties": {
        "registryGroupsApplied": {
          "type": "array",
          "items": { "type": "string" }
        },
        "registryGroups": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "description",
              "scope",
              "risk",
              "reversible",
              "phase",
              "intent",
              "status",
              "setOperations",
              "removeOperations",
              "rollbackOperations",
              "rollbackCoverage",
              "error"
            ],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" },
              "scope": { "type": "string" },
              "risk": { "type": "string", "enum": ["low", "medium", "high"] },
              "reversible": { "type": "boolean" },
              "phase": { "type": "string" },
              "intent": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["pending", "applied", "skipped-not-selected", "skipped-conditional", "failed"]
              },
              "setOperations": { "type": "integer", "minimum": 0 },
              "removeOperations": { "type": "integer", "minimum": 0 },
              "rollbackOperations": { "type": "integer", "minimum": 0 },
              "rollbackCoverage": { "type": "string", "enum": ["none", "partial", "full"] },
              "error": { "type": "string" }
            }
          }
        }
      }
    },
    "policies": {
      "type": "object",
      "required": ["homePrivacy", "laptopDefaults", "locationPosture", "storageSense", "modernStandby", "wpbt", "dualBootClock"],
      "additionalProperties": false,
      "properties": {
        "homePrivacy": {
          "type": "object",
          "required": ["enabled", "telemetry", "allowTelemetry"],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "telemetry": { "type": "string" },
            "allowTelemetry": { "type": "integer" }
          }
        },
        "laptopDefaults": {
          "type": "object",
          "required": ["enabled"],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "locationPosture": {
          "type": "object",
          "required": ["enabled", "findMyDeviceAllowed"],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "findMyDeviceAllowed": { "type": "boolean" }
          }
        },
        "storageSense": {
          "type": "object",
          "required": ["enabled", "downloadsCleanup"],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "downloadsCleanup": { "type": "string" }
          }
        },
        "modernStandby": {
          "type": "object",
          "required": ["networkConnectivity"],
          "additionalProperties": false,
          "properties": {
            "networkConnectivity": { "type": "string" }
          }
        },
        "wpbt": {
          "type": "object",
          "required": ["disableWpbtExecution"],
          "additionalProperties": false,
          "properties": {
            "disableWpbtExecution": { "type": "boolean" }
          }
        },
        "dualBootClock": {
          "type": "object",
          "required": ["realTimeIsUniversal"],
          "additionalProperties": false,
          "properties": {
            "realTimeIsUniversal": { "type": "boolean" }
          }
        }
      }
    },
    "drivers": {
      "type": "object",
      "required": ["source", "injectedCount", "infNames"],
      "additionalProperties": false,
      "properties": {
        "source": { "type": "string" },
        "path": { "type": "string" },
        "strategy": { "type": "string" },
        "injectedCount": {
          "type": "integer",
          "minimum": 0
        },
        "infNames": {
          "type": "array",
          "items": { "type": "string" }
        },
        "includedClasses": {
          "type": "array",
          "items": { "type": "string" }
        },
        "excludedClasses": {
          "type": "array",
          "items": { "type": "string" }
        },
        "excludedCount": {
          "type": "integer",
          "minimum": 0
        },
        "inventoryPath": {
          "type": "string"
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "surface": {
          "type": "object",
          "required": ["deviceId", "deviceName", "architecture", "downloadCenterId", "detailsUrl", "packageFileName", "packageUrl", "sha256"],
          "additionalProperties": false,
          "properties": {
            "deviceId": { "type": "string" },
            "deviceName": { "type": "string" },
            "architecture": { "type": "string" },
            "downloadCenterId": { "type": "string" },
            "detailsUrl": { "type": "string" },
            "packageFileName": { "type": "string" },
            "packageUrl": { "type": "string" },
            "sha256": { "type": "string" }
          }
        }
      }
    },
    "payloads": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "sourceUrl", "version", "sha256", "sizeBytes"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "sourceUrl": { "type": "string" },
          "version": { "type": "string" },
          "sha256": { "type": "string" },
          "sizeBytes": { "type": "integer" }
        }
      }
    },
    "firstLogon": {
      "type": "object",
      "required": ["editors", "wslDistros", "desktopLayers"],
      "additionalProperties": false,
      "properties": {
        "editors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "wslDistros": {
          "type": "array",
          "items": { "type": "string" }
        },
        "desktopLayers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "wingetConfigurationPath": {
          "type": "string"
        },
        "wingetConfigurationPackageCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "audit": {
      "type": "object",
      "required": ["buildDeltaCount", "records"],
      "additionalProperties": false,
      "properties": {
        "schemaVersion": {
          "type": "integer",
          "minimum": 1
        },
        "generatedAt": {
          "type": "string"
        },
        "records": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "phase", "kind", "title", "userControlled", "changes"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "phase": { "type": "string" },
              "kind": { "type": "string" },
              "title": { "type": "string" },
              "userControlled": { "type": "boolean" },
              "changes": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "buildDeltaCount": {
          "type": "integer",
          "minimum": 0
        },
        "buildDeltaPath": {
          "type": "string"
        }
      }
    },
    "riskFlags": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
