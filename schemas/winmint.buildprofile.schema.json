{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://winmint.yanai.sh/schemas/winmint.buildprofile.schema.json",
  "title": "WinMint Build Profile",
  "type": "object",
  "required": [
    "schemaVersion",
    "createdAt",
    "profileName",
    "keep",
    "source",
    "target",
    "identity",
    "regional",
    "drivers",
    "desktop",
    "development",
    "removals",
    "posture",
    "privacy"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "identity": {
            "properties": {
              "passwordIncluded": { "const": true }
            }
          }
        }
      },
      "then": {
        "properties": {
          "identity": {
            "required": ["password"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "target": {
            "properties": {
              "diskMode": { "const": "DualBootReserved" }
            }
          }
        }
      },
      "then": {
        "properties": {
          "target": {
            "properties": {
              "diskLayout": {
                "properties": {
                  "preset": { "enum": ["WindowsHeavy", "Balanced", "EvenSplit", "LinuxHeavy"] }
                }
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "target": {
            "properties": {
              "diskLayout": {
                "properties": {
                  "preset": { "const": "" }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["development"],
        "properties": {
          "development": {
            "required": ["browsers"],
            "properties": {
              "browsers": {
                "contains": { "const": "edge" }
              }
            }
          }
        }
      },
      "then": {
        "required": ["keep"],
        "properties": {
          "keep": {
            "required": ["edge"],
            "properties": {
              "edge": { "const": true }
            }
          }
        }
      }
    }
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 4 },
    "createdAt": { "type": "string" },
    "profileName": { "type": "string" },
    "keep": {
      "type": "object",
      "required": ["edge", "gaming", "copilot"],
      "properties": {
        "edge": { "type": "boolean" },
        "gaming": { "type": "boolean" },
        "copilot": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": ["isoPath", "architecture"],
      "properties": {
        "isoPath": { "type": "string" },
        "architecture": { "type": "string", "enum": ["amd64", "arm64", "x86", ""] }
      },
      "additionalProperties": false
    },
    "target": {
      "type": "object",
      "required": ["device", "editionMode", "edition", "diskMode", "diskLayout"],
      "properties": {
        "device": { "type": "string", "enum": ["ThisPC", "DifferentPC"] },
        "formFactor": { "type": "string", "enum": ["Auto", "Laptop", "Desktop"] },
        "powerPlan": { "type": "string", "enum": ["Balanced", "EnergySaver", "HighPerformance", "UltimatePerformance"] },
        "editionMode": { "type": "string", "enum": ["TargetLicense", "Fixed"] },
        "edition": { "type": "string" },
        "productKey": { "type": "string" },
        "diskMode": { "type": "string", "enum": ["Manual", "AutoWipeDisk0", "DualBootReserved"] },
        "diskLayout": {
          "type": "object",
          "required": [
            "preset",
            "roundingGb",
            "windowsMinimumGb",
            "windowsRecommendedGb",
            "linuxMinimumGb",
            "linuxRecommendedGb",
            "efiMb",
            "msrMb",
            "recoveryMb"
          ],
          "properties": {
            "preset": { "type": "string", "enum": ["", "WindowsHeavy", "Balanced", "EvenSplit", "LinuxHeavy"] },
            "roundingGb": { "type": "integer", "const": 64 },
            "windowsMinimumGb": { "type": "integer", "minimum": 256 },
            "windowsRecommendedGb": { "type": "integer", "minimum": 384 },
            "linuxMinimumGb": { "type": "integer", "minimum": 128 },
            "linuxRecommendedGb": { "type": "integer", "minimum": 256 },
            "efiMb": { "type": "integer", "const": 1024 },
            "msrMb": { "type": "integer", "const": 16 },
            "recoveryMb": { "type": "integer", "const": 1024 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "identity": {
      "type": "object",
      "required": ["computerName", "accountName", "autoLogon", "passwordSet", "passwordIncluded"],
      "properties": {
        "computerName": { "type": "string" },
        "accountName": { "type": "string" },
        "accountMode": { "type": "string", "enum": ["Local", "MicrosoftOobe"] },
        "autoLogon": { "type": "boolean" },
        "passwordSet": { "type": "boolean" },
        "passwordIncluded": { "type": "boolean" },
        "password": { "type": "string" }
      },
      "additionalProperties": false
    },
    "regional": {
      "type": "object",
      "required": ["timeZoneId", "uiLanguage", "systemLocale", "uiLanguageFallback", "userLocale", "inputLocale"],
      "properties": {
        "timeZoneId": { "type": "string" },
        "uiLanguage": { "type": "string" },
        "systemLocale": { "type": "string" },
        "uiLanguageFallback": { "type": "string" },
        "userLocale": { "type": "string" },
        "inputLocale": { "type": "string" },
        "homeLocationGeoId": { "type": "integer" },
        "secondaryInputLanguages": {
          "description": "Secondary input languages (keyboards) to add for the user while the display language stays en-US. 'Auto' (default) replicates the build host's current keyboard config; 'None' or [] adds none; an array of BCP-47 tags (e.g. ['he-IL']) sets them explicitly.",
          "oneOf": [
            { "type": "string", "enum": ["Auto", "None"] },
            { "type": "array", "items": { "type": "string" } }
          ]
        }
      },
      "additionalProperties": false
    },
    "drivers": {
      "type": "object",
      "required": ["source", "path", "exportHostDrivers"],
      "allOf": [
        {
          "if": {
            "required": ["source"],
            "properties": {
              "source": { "enum": ["Host", "HostExport"] }
            }
          },
          "then": {
            "properties": {
              "exportHostDrivers": { "const": true }
            }
          }
        },
        {
          "if": {
            "required": ["source"],
            "properties": {
              "source": { "const": "None" }
            }
          },
          "then": {
            "properties": {
              "exportHostDrivers": { "const": false }
            }
          }
        }
      ],
      "properties": {
        "source": { "type": "string", "enum": ["None", "Host", "Custom", "HostExport", "CustomInfFolder", "OemMsi", "SurfaceMsiSafe", "SurfaceCatalog"] },
        "path": { "type": "string" },
        "exportHostDrivers": { "type": "boolean" },
        "hostMirrorFilter": { "type": "string", "enum": ["full", "setup-critical"] }
      },
      "additionalProperties": false
    },
    "desktop": {
      "type": "object",
      "required": ["cursorPack", "layers"],
      "properties": {
        "cursorPack": { "type": "string", "const": "Windows11Modern" },
        "layers": {
          "type": "array",
          "items": { "type": "string", "enum": ["standard", "windhawk", "yasb", "thide", "komorebi", "nilesoft"] },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "development": {
      "type": "object",
      "required": ["editors", "browsers", "wsl"],
      "properties": {
        "editors": {
          "type": "array",
          "items": { "type": "string", "enum": ["cursor", "vscode", "zed", "antigravity", "neovim"] },
          "uniqueItems": true
        },
        "browsers": {
          "type": "array",
          "items": { "type": "string", "enum": ["zen-browser", "helium", "firefox-developer-edition", "brave", "edge"] },
          "uniqueItems": true
        },
        "wsl": {
          "type": "object",
          "required": ["distros"],
          "properties": {
            "distros": {
              "type": "array",
              "items": { "type": "string", "enum": ["Ubuntu", "FedoraLinux", "archlinux", "NixOS-WSL", "pengwin"] },
              "uniqueItems": true
            }
          },
          "additionalProperties": false
        },
        "dotfiles": {
          "type": "object",
          "required": ["repository"],
          "properties": {
            "repository": { "type": "string", "pattern": "^https://.+" },
            "ref": { "type": "string", "minLength": 1 },
            "installScript": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "features": {
      "type": "object",
      "required": ["launcher"],
      "properties": {
        "launcher": { "type": "string", "enum": ["None"] },
        "liveInstallAudit": { "type": "boolean" },
        "phoneLink": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "updates": {
      "type": "object",
      "required": [
        "mode",
        "targetFeatureVersion",
        "releaseCadence",
        "includeOptionalPreviews",
        "payloadRoot",
        "qualitySecurity",
        "dynamicUpdate",
        "defender",
        "dotnet",
        "provisionedApps"
      ],
      "properties": {
        "mode": { "type": "string", "enum": ["None", "Stable25H2"] },
        "targetFeatureVersion": { "type": "string", "const": "25H2" },
        "releaseCadence": { "type": "string", "const": "BRelease" },
        "includeOptionalPreviews": { "type": "boolean", "const": false },
        "payloadRoot": { "type": "string" },
        "qualitySecurity": { "type": "boolean" },
        "dynamicUpdate": { "type": "boolean" },
        "defender": { "type": "boolean" },
        "dotnet": { "type": "boolean" },
        "provisionedApps": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "removals": {
      "type": "object",
      "required": ["aiPolicy"],
      "properties": {
        "aiPolicy": { "type": "string", "enum": ["Core", "ServiceableFull", "AggressiveExperimental"] }
      },
      "additionalProperties": false
    },
    "posture": {
      "type": "object",
      "required": ["appearance", "explorer", "accessibility", "setup"],
      "properties": {
        "appearance": {
          "type": "object",
          "required": ["theme"],
          "properties": {
            "theme": { "type": "string", "enum": ["dark", "light"] }
          },
          "additionalProperties": false
        },
        "explorer": {
          "type": "object",
          "required": ["showFileExtensions", "showHiddenFiles"],
          "properties": {
            "showFileExtensions": { "type": "boolean" },
            "showHiddenFiles": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "accessibility": {
          "type": "object",
          "required": ["stickyKeys"],
          "properties": {
            "stickyKeys": { "type": "string", "enum": ["enabled", "disabled"] }
          },
          "additionalProperties": false
        },
        "setup": {
          "type": "object",
          "required": ["dmaInterop", "hardwareBypass"],
          "properties": {
            "dmaInterop": { "type": "boolean" },
            "hardwareBypass": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "privacy": {
      "type": "object",
      "required": ["locationServices", "telemetryTracing", "advertisingId", "activityHistory"],
      "properties": {
        "locationServices": { "type": "string", "enum": ["enabled", "disabled"] },
        "telemetryTracing": { "type": "string", "enum": ["default", "disabled"] },
        "advertisingId": { "type": "string", "enum": ["enabled", "disabled"] },
        "activityHistory": { "type": "string", "enum": ["enabled", "disabled"] }
      },
      "additionalProperties": false
    },
    "diagnostics": {
      "type": "object",
      "properties": {
        "retainFirstLogonArtifacts": { "type": "boolean" },
        "provisioningShellDwellMs": { "type": "integer", "minimum": 0 },
        "wslRuntimeValidation": { "type": "string", "enum": ["full", "skip"] },
        "vmGuestBasicConsole": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
